//8. Rotate Array Left
// 2 3 4 5 1
import java.util.*;
class Main {
    public static void main(String[] args) {
   int arr[]={1,2,3,4,5};
   int first=arr[0];
   for(int i=0;i<arr.length-1;i++){
       arr[i]=arr[i+1];
   }
   arr[arr.length-1]=first;
   for(int i:arr){
       System.out.print(i+" ");
   }
    }
}

//8. Rotate Array right
// {5, 1, 2, 3, 4}
import java.util.*;
class Main {
    public static void main(String[] args) {
   int arr[]={1,2,3,4,5};
   int first=arr[arr.length-1];
   for(int i=arr.length-1;i>0;i--){
       arr[i]=arr[i-1];
   }
   arr[0]=first;
   for(int i:arr){
       System.out.print(i+" ");
   }
    }
}

