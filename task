//Maximum Product Pair

class Main {
    public static void main(String[] args) {
    int arr[]={1,7,3,9,5};
    int max=0;
    int f=0;
    int s=0;
    for(int i=0;i<arr.length;i++){
        for(int j=i+1;j<arr.length;j++){
            int sum=arr[i]*arr[j];
            if(sum>max){
                max=sum;
                f=arr[i];
                s=arr[j];
            }
        }
    }
    System.out.println(f+" "+s);
    }
}

